<link rel="stylesheet" href="./all.min.css">
<style>
/* ===== Theme Variables ===== */
:root {
    --primary: #1a73e8; --primary-dark: #1557b0; --primary-light: #e8f0fe;
    --secondary: #0097a7; --danger: #d93025; --warning: #e65100; --success: #1e8e3e;
    --bg-dark: #f0f2f5; --bg-card: #ffffff; --bg-hover: #e8eaed;
    --text-primary: #202124; --text-secondary: #5f6368; --border: #dadce0;
    --shadow: rgba(0,0,0,0.08); --input-bg: #ffffff; --input-border: #dadce0;
}
:root[data-theme="dark"] {
    --primary: #1e6fdb; --primary-dark: #1557b0; --primary-light: #e8f1fd;
    --secondary: #00b4d8; --danger: #ef4444; --warning: #f59e0b; --success: #10b981;
    --bg-dark: #0a1628; --bg-card: #112240; --bg-hover: #1a2f4a;
    --text-primary: #e2e8f0; --text-secondary: #94a3b8; --border: #1e3a5f;
    --shadow: rgba(0,0,0,0.3); --input-bg: rgba(255,255,255,0.05); --input-border: #1e3a5f;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
body {
    font-family: 'Microsoft YaHei', 'PingFang SC', -apple-system, sans-serif;
    background: var(--bg-dark);
    color: var(--text-primary);
    padding: 20px;
    padding-bottom: 100px;
    min-height: 100vh;
}

/* ===== Breadcrumb & Title ===== */
.page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
}
.breadcrumb {
    font-size: 13px;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
}
.breadcrumb a {
    color: var(--primary);
    text-decoration: none;
    cursor: pointer;
}
.breadcrumb a:hover { text-decoration: underline; }
.breadcrumb-sep { color: var(--text-secondary); opacity: 0.5; }
.page-title {
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
}
.page-title i { color: var(--primary); }

/* ===== Section Card ===== */
.section-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 16px;
    overflow: hidden;
    box-shadow: 0 1px 3px var(--shadow);
}
.section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 18px;
    background: var(--bg-hover);
    border-bottom: 1px solid var(--border);
    font-size: 15px;
    font-weight: 700;
}
.section-header i { color: var(--primary); font-size: 14px; }
.section-body { padding: 18px; }

/* ===== Info Grid ===== */
.info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px 24px;
}
.info-item { display: flex; flex-direction: column; gap: 4px; }
.info-label { font-size: 12px; color: var(--text-secondary); }
.info-value { font-size: 14px; font-weight: 500; color: var(--text-primary); }

/* Risk badge */
.risk-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
}
.risk-badge::before {
    content: '';
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
}
.risk-badge.red { background: rgba(217,48,37,0.1); color: var(--danger); }
.risk-badge.red::before { background: var(--danger); }
.risk-badge.orange { background: rgba(227,116,0,0.1); color: var(--warning); }
.risk-badge.orange::before { background: var(--warning); }
.risk-badge.yellow { background: rgba(199,128,0,0.1); color: #c78000; }
.risk-badge.yellow::before { background: #c78000; }
.risk-badge.blue { background: rgba(26,115,232,0.1); color: var(--primary); }
.risk-badge.blue::before { background: var(--primary); }

/* Status tag */
.status-tag {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
}
.status-tag.pending      { background: rgba(217,48,37,0.1);  color: var(--danger); }
.status-tag.dispatch     { background: rgba(227,116,0,0.1);  color: var(--warning); }
.status-tag.handling     { background: rgba(26,115,232,0.1); color: var(--primary); }
.status-tag.accept       { background: rgba(142,36,170,0.1); color: #8e24aa; }
.status-tag.closed       { background: rgba(30,142,62,0.1);  color: var(--success); }
.status-tag.reject-audit { background: rgba(100,100,100,0.1); color: var(--text-secondary); }
.status-tag.reject-check { background: rgba(100,100,100,0.1); color: var(--text-secondary); }
.status-tag.overdue      { background: rgba(217,48,37,0.15); color: var(--danger); }

/* ===== Monitor Data Table ===== */
.data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
}
.data-table thead { background: var(--bg-hover); }
.data-table th {
    padding: 12px 16px;
    text-align: left;
    font-weight: 600;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
}
.data-table td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
    line-height: 1.5;
}
.data-table tbody tr:last-child td { border-bottom: none; }

/* ===== Evidence Gallery ===== */
.evidence-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
}
.evidence-item {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-card);
}
.evidence-thumb {
    width: 100%;
    height: 120px;
    background: var(--bg-hover);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    font-size: 32px;
}
.evidence-info {
    padding: 8px 10px;
    font-size: 12px;
    color: var(--text-secondary);
}

/* ===== GIS Map Embed ===== */
.gis-map-container {
    width: 100%;
    height: 360px;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    background: var(--bg-hover);
    border: 1px solid var(--border);
}
.gis-map-placeholder {
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--text-secondary);
    position: relative;
}
.gis-map-placeholder::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background:
        linear-gradient(rgba(26,115,232,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(26,115,232,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
}
.gis-map-placeholder i { font-size: 48px; color: var(--primary); opacity: 0.3; position: relative; z-index: 1; }
.gis-map-placeholder span { font-size: 14px; position: relative; z-index: 1; }
.gis-map-info {
    position: absolute;
    bottom: 12px; left: 12px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 12px;
    z-index: 2;
    box-shadow: 0 2px 8px var(--shadow);
}
.gis-map-info-item {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 4px;
}
.gis-map-info-item:last-child { margin-bottom: 0; }
.gis-map-info-item i { font-size: 12px; color: var(--primary); opacity: 1; }
.gis-map-info-item .coord-label { color: var(--text-secondary); min-width: 48px; }
.gis-map-info-item .coord-value { color: var(--text-primary); font-weight: 600; font-family: 'Consolas', monospace; }
.gis-map-marker {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -100%);
    z-index: 2;
}
.gis-map-marker i { font-size: 32px; color: var(--danger); opacity: 1; filter: drop-shadow(0 2px 4px rgba(217,48,37,0.4)); }
.gis-map-marker::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 50%;
    transform: translateX(-50%);
    width: 12px; height: 6px;
    background: rgba(217,48,37,0.3);
    border-radius: 50%;
    filter: blur(2px);
}

/* ===== Two Column Layout ===== */
.two-column-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 16px;
    align-items: start;
}
.left-column { min-width: 0; }
.right-column {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 20px;
}

/* ===== Tab Navigation in Left Column ===== */
.left-tabs {
    display: flex;
    gap: 4px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 6px;
    margin-bottom: 16px;
    box-shadow: 0 1px 3px var(--shadow);
}
.left-tab-btn {
    flex: 1;
    height: 40px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}
.left-tab-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
.left-tab-btn.active { background: var(--primary); color: #fff; }
.left-tab-btn i { font-size: 14px; }
.left-tab-panel { display: none; }
.left-tab-panel.active { display: block; }

/* ===== Collapsible Card ===== */
.collapsible-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 12px;
    overflow: hidden;
}
.collapsible-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    background: var(--bg-hover);
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.2s;
}
.collapsible-header:hover { background: var(--border); }
.collapsible-header-left { display: flex; align-items: center; gap: 10px; }
.collapsible-header-left i { color: var(--primary); font-size: 14px; }
.collapsible-header-title { font-size: 15px; font-weight: 700; color: var(--text-primary); }
.collapsible-header-status {
    font-size: 12px;
    padding: 2px 10px;
    border-radius: 12px;
    background: var(--primary-light);
    color: var(--primary);
    font-weight: 600;
}
.collapsible-header-status.completed { background: rgba(30,142,62,0.1); color: var(--success); }
.collapsible-toggle { font-size: 14px; color: var(--text-secondary); transition: transform 0.3s; }
.collapsible-card.expanded .collapsible-toggle { transform: rotate(180deg); }
.collapsible-body { padding: 18px; display: none; }
.collapsible-card.expanded .collapsible-body { display: block; }

/* ===== Process Record ===== */
.process-record-list { display: flex; flex-direction: column; gap: 12px; }
.process-record-item {
    display: flex;
    gap: 12px;
    padding: 12px;
    background: var(--bg-hover);
    border-radius: 8px;
}
.process-record-time { font-size: 12px; color: var(--text-secondary); white-space: nowrap; min-width: 80px; }
.process-record-content { flex: 1; font-size: 13px; color: var(--text-primary); line-height: 1.5; }
.process-record-author { font-size: 12px; color: var(--primary); font-weight: 600; margin-bottom: 4px; }

/* ===== Audit History Timeline ===== */
.audit-history-timeline {
    position: relative;
    padding-left: 28px;
}
.audit-history-timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--border);
    border-radius: 1px;
}
.audit-history-item { position: relative; padding-bottom: 16px; }
.audit-history-item:last-child { padding-bottom: 0; }
.audit-history-dot {
    position: absolute;
    left: -24px;
    top: 4px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    flex-shrink: 0;
}
.audit-history-dot.blue { background: var(--primary); color: #fff; }
.audit-history-dot.blue::after {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #fff;
}
.audit-history-dot.green { background: var(--success); color: #fff; }
.audit-history-dot.green i { font-size: 10px; }
.audit-history-content {
    background: var(--bg-hover);
    border-radius: 8px;
    padding: 12px 14px;
}
.audit-history-title { font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; }
.audit-history-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 6px;
}
.audit-history-meta i { font-size: 11px; color: var(--primary); }
.audit-history-desc { font-size: 13px; color: var(--text-primary); line-height: 1.5; }

/* ===== Audit History Card ===== */
.audit-history-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 3px var(--shadow);
}
.audit-history-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 18px;
    background: var(--bg-hover);
    border-bottom: 1px solid var(--border);
    font-size: 15px;
    font-weight: 700;
}
.audit-history-header i { color: var(--primary); font-size: 14px; }
.audit-history-body { padding: 18px; }

/* ===== Form Textarea ===== */
.form-textarea {
    width: 100%;
    min-height: 100px;
    padding: 12px;
    border: 1px solid var(--input-border);
    border-radius: 8px;
    background: var(--input-bg);
    color: var(--text-primary);
    font-size: 14px;
    line-height: 1.6;
    resize: vertical;
    outline: none;
    font-family: inherit;
}
.form-textarea:focus { border-color: var(--primary); }
.form-textarea::placeholder { color: var(--text-secondary); opacity: 0.6; }

/* ===== Photo Grid ===== */
.photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 12px;
}
.photo-item {
    aspect-ratio: 1;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-hover);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
}
.photo-item:hover { border-color: var(--primary); }
.photo-item i { font-size: 20px; color: var(--text-secondary); }
.photo-item.add-btn { border-style: dashed; }
.photo-item.add-btn:hover { background: var(--primary-light); border-color: var(--primary); }
.photo-item.add-btn i { color: var(--primary); }

/* ===== Upload Area ===== */
.upload-area {
    border: 2px dashed var(--border);
    border-radius: 8px;
    padding: 24px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 12px;
}
.upload-area:hover { border-color: var(--primary); background: var(--primary-light); }
.upload-area i { font-size: 24px; color: var(--primary); margin-bottom: 8px; }
.upload-area-text { font-size: 13px; color: var(--text-secondary); }
.upload-area-hint { font-size: 12px; color: var(--text-secondary); opacity: 0.7; margin-top: 4px; }

/* ===== Form Group ===== */
.form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
.form-sublabel { font-size: 13px; font-weight: 600; color: var(--text-primary); }

/* ===== Attachment List ===== */
.attachment-list { display: flex; flex-direction: column; gap: 8px; margin-top: 12px; }
.attachment-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    background: var(--bg-hover);
    border-radius: 6px;
    font-size: 13px;
}
.attachment-item i { color: var(--primary); font-size: 14px; }
.attachment-name { flex: 1; color: var(--text-primary); }
.attachment-size { font-size: 12px; color: var(--text-secondary); }
.attachment-remove { cursor: pointer; color: var(--text-secondary); font-size: 12px; }
.attachment-remove:hover { color: var(--danger); }
</style>
</head>
