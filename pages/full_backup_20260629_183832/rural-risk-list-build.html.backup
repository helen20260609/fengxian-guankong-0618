                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">排序</label>
                    <input type="number" class="form-control" value="1" min="1" style="text-align:center">
                </div>
            </div>
            <!-- Row 7: 主要防范措施 -->
            <div class="form-group" style="margin-bottom:16px">
                <label class="form-label">主要防范措施 <span style="font-weight:400">（从措施库中选择关联）</span></label>
                <div style="padding:12px 14px;background:var(--bg-dark);border:1px solid var(--border);border-radius:6px;margin-bottom:10px">
                    <div style="font-size:12px;color:var(--text-secondary);margin-bottom:8px">已关联措施：</div>
                    <div style="display:flex;gap:6px;flex-wrap:wrap;min-height:28px">
                        <span class="measure-tag">暂无关联措施 <span class="remove" onclick="this.parentElement.remove()">×</span></span>
                    </div>
                </div>
                <div style="display:flex;gap:8px;align-items:center">
                    <button class="btn btn-outline" style="padding:6px 12px;font-size:12px" onclick="openModal('modal-select-measure')">＋ 从措施库选择</button>
                    <span style="font-size:12px;color:var(--text-secondary)">或直接编辑措施文本 ↓</span>
                </div>
                <textarea class="form-control" rows="2" style="margin-top:8px" placeholder="可手动编辑防范措施文本，或从措施库选择后自动填充..."></textarea>
            </div>
            <!-- Row 8: 工作依据 -->
            <div class="form-group" style="margin-bottom:16px">
                <label class="form-label">工作依据 <span style="font-weight:400">（从工作依据库中选择）</span></label>
                <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;">
                    <span class="tag-item" onclick="this.classList.toggle('selected')">《农村住房安全性鉴定技术导则》</span>
                    <span class="tag-item" onclick="this.classList.toggle('selected')">《危险房屋鉴定标准》JGJ125</span>
                    <span class="tag-item" onclick="this.classList.toggle('selected')">《民用建筑可靠性鉴定标准》GB50292</span>
                    <span style="color:var(--border)">|</span>
                    <input type="text" class="tag-add-input" placeholder="自定义依据" style="width:90px">
                    <button class="tag-add-btn" onclick="addCustomTag(this)">＋</button>
                </div>
            </div>
            <!-- Row 9: 备注 -->
            <div class="form-group" style="margin-bottom:0">
                <label class="form-label">备注</label>
                <textarea class="form-control" rows="2" placeholder="补充说明..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('modal-new-item')">取消</button>
            <button class="btn btn-primary" onclick="closeModal('modal-new-item')">确认新增</button>
        </div>
    </div>
</div>

<!-- 选择防范措施 -->
<div class="modal-overlay" id="modal-select-measure">
    <div class="modal-box" style="max-width:800px">
        <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-shield-halved" style="color:var(--primary)"></i> 选择防范措施</div>
            <button class="modal-close" onclick="closeModal('modal-select-measure')">×</button>
        </div>
        <div class="modal-body">
            <div style="display:flex;gap:10px;margin-bottom:12px">
                <input type="text" class="form-control" id="measureSearchInput" placeholder="🔍 搜索措施名称或关键词..." style="flex:1">
                <select class="form-control" id="measureRiskFilter" style="width:140px">
                    <option value="">全部等级</option>
                    <option>红色（重大）</option>
                    <option>橙色（较大）</option>
                    <option>黄色（一般）</option>
                    <option>蓝色（低）</option>
                </select>
                <button class="btn btn-outline" onclick="filterMeasureTable()"><i class="fa-solid fa-search"></i> 查询</button>
            </div>
            <div class="select-bar">
                <span><input type="checkbox" id="ckAllMeasures" onclick="toggleAllMeasures(this.checked)" style="width:16px;height:16px;cursor:pointer;accent-color:var(--primary);margin-right:6px"> 全选</span>
                <span>已选 <span class="sel-count" id="selMeasureCount">0</span> 条</span>
            </div>
            <div style="border:1px solid var(--border);border-radius:8px;overflow:hidden;max-height:360px;overflow-y:auto">
                <table class="select-measure-table">
                    <thead>
                        <tr>
                            <th style="width:40px;text-align:center"></th>
                            <th>措施名称</th>
                            <th>措施描述</th>
                            <th style="width:100px;text-align:center">适用风险等级</th>
                            <th style="width:80px;text-align:center">责任人</th>
                        </tr>
                    </thead>
                    <tbody id="measureSelectBody">
                        <tr>
                            <td><input type="checkbox" class="measure-ck" data-name="维修加固"></td>
                            <td><div class="smt-name">维修加固</div></td>
                            <td><div class="smt-desc">对地基基础、墙体、梁柱等结构构件进行加固维修，恢复结构承载力</div></td>
                            <td style="text-align:center"><span class="smt-risk red">重大</span></td>
                            <td style="text-align:center">结构工程师</td>
                        </tr>
                        <tr>
                            <td><input type="checkbox" class="measure-ck" data-name="安全鉴定"></td>
                            <td><div class="smt-name">安全鉴定</div></td>
                            <td><div class="smt-desc">委托专业机构进行房屋安全鉴定，出具鉴定报告并提出整改建议</div></td>
                            <td style="text-align:center"><span class="smt-risk red">重大</span></td>
                            <td style="text-align:center">房屋鉴定机构</td>
                        </tr>
                        <tr>
                            <td><input type="checkbox" class="measure-ck" data-name="拆除重建"></td>
                            <td><div class="smt-name">拆除重建</div></td>
                            <td><div class="smt-desc">对D级危房进行拆除重建，确保新建房屋符合安全标准</div></td>
                            <td style="text-align:center"><span class="smt-risk red">重大</span></td>
                            <td style="text-align:center">施工单位</td>
                        </tr>
                        <tr>
                            <td><input type="checkbox" class="measure-ck" data-name="定期检查"></td>
                            <td><div class="smt-name">定期检查</div></td>
                            <td><div class="smt-desc">建立农村自建房定期检查制度，对老旧房屋进行巡查监测</div></td>
                            <td style="text-align:center"><span class="smt-risk orange">较大</span></td>
                            <td style="text-align:center">村委会</td>
                        </tr>
                        <tr>
                            <td><input type="checkbox" class="measure-ck" data-name="限制使用"></td>
                            <td><div class="smt-name">限制使用</div></td>
                            <td><div class="smt-desc">对存在隐患的房屋限制居住人数或用途，设置警示标识</div></td>
                            <td style="text-align:center"><span class="smt-risk orange">较大</span></td>
                            <td style="text-align:center">乡镇政府</td>
                        </tr>
                        <tr>
                            <td><input type="checkbox" class="measure-ck" data-name="防水处理"></td>
                            <td><div class="smt-name">防水处理</div></td>
                            <td><div class="smt-desc">对屋面、墙体进行防水处理，防止渗漏导致结构损坏</div></td>
                            <td style="text-align:center"><span class="smt-risk yellow">一般</span></td>
                            <td style="text-align:center">维修人员</td>
                        </tr>
                        <tr>
                            <td><input type="checkbox" class="measure-ck" data-name="白蚁防治"></td>
                            <td><div class="smt-name">白蚁防治</div></td>
                            <td><div class="smt-desc">对木质结构进行白蚁防治处理，防止虫害侵蚀</div></td>
                            <td style="text-align:center"><span class="smt-risk yellow">一般</span></td>
                            <td style="text-align:center">防治机构</td>
                        </tr>
                        <tr>
                            <td><input type="checkbox" class="measure-ck" data-name="档案管理"></td>
                            <td><div class="smt-name">档案管理</div></td>
                            <td><div class="smt-desc">建立农村自建房安全档案，记录检查、维修、鉴定等信息</div></td>
                            <td style="text-align:center"><span class="smt-risk blue">低</span></td>
                            <td style="text-align:center">管理人员</td>
                        </tr>
                        <tr>
                            <td><input type="checkbox" class="measure-ck" data-name="宣传教育"></td>
                            <td><div class="smt-name">宣传教育</div></td>
                            <td><div class="smt-desc">开展农村自建房安全知识宣传，提高村民安全意识</div></td>
                            <td style="text-align:center"><span class="smt-risk blue">低</span></td>
                            <td style="text-align:center">宣传部门</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('modal-select-measure')">取消</button>
            <button class="btn btn-primary" onclick="confirmSelectMeasure()"><i class="fa-solid fa-check"></i> 确认选择</button>
        </div>
    </div>
</div>

<!-- 删除确认 -->
<div class="modal-overlay" id="modal-delete-confirm">
    <div class="modal-box" style="max-width:420px">
        <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--danger);margin-right:6px"></i>确认删除</div>
            <button class="modal-close" onclick="closeModal('modal-delete-confirm')">×</button>
        </div>
        <div class="modal-body" style="text-align:center;padding:30px 20px">
            <div style="font-size:48px;color:var(--danger);margin-bottom:16px"><i class="fa-solid fa-circle-exclamation"></i></div>
            <div style="font-size:15px;margin-bottom:8px;color:var(--text-primary)">确定要删除该风险条目吗？</div>
            <div style="font-size:13px;color:var(--text-secondary)">删除后将无法恢复，请确认操作</div>
        </div>
        <div class="modal-footer" style="justify-content:center">
            <button class="btn btn-outline" onclick="closeModal('modal-delete-confirm')">取消</button>
            <button class="btn btn-primary" style="background:var(--danger)" onclick="closeModal('modal-delete-confirm')"><i class="fa-solid fa-trash"></i> 确认删除</button>
        </div>
    </div>
</div>

<!-- 批量导入 -->
<div class="modal-overlay" id="modal-import-template">
    <div class="modal-box" style="max-width:560px">
        <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-file-import" style="color:var(--primary);margin-right:6px"></i>批量导入风险条目</div>
            <button class="modal-close" onclick="closeModal('modal-import-template')">×</button>
        </div>
        <div class="modal-body">
            <div style="padding:10px 14px;background:rgba(30,111,219,0.1);border:1px solid rgba(30,111,219,0.2);border-radius:8px;font-size:12px;color:var(--text-secondary);margin-bottom:16px">
                <i class="fa-solid fa-circle-info" style="color:var(--primary);margin-right:4px"></i>
                请下载标准模板，按照模板格式填写后上传导入
            </div>
            <div style="margin-bottom:16px">
                <button class="btn btn-outline"><i class="fa-solid fa-download"></i> 下载导入模板</button>
            </div>
            <div style="border:2px dashed var(--border);border-radius:10px;padding:40px;text-align:center;cursor:pointer;transition:border-color 0.3s" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
                <div style="font-size:36px;color:var(--primary);margin-bottom:12px"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                <div style="font-size:14px;color:var(--text-primary);margin-bottom:4px">点击或拖拽文件至此区域上传</div>
                <div style="font-size:12px;color:var(--text-secondary)">支持 .xlsx, .xls, .csv 格式，单次最大10MB</div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('modal-import-template')">取消</button>
            <button class="btn btn-primary"><i class="fa-solid fa-upload"></i> 开始导入</button>
        </div>
    </div>
</div>

<script>
// ========== Theme sync ==========
(function() {
    var saved = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', saved);
})();

window.addEventListener('message', function(event) {
    if (event.data && event.data.action === 'setTheme') {
        document.documentElement.setAttribute('data-theme', event.data.theme);
        localStorage.setItem('theme', event.data.theme);
    }
});

// Toggle tree group expand/collapse
function toggleTreeGroup(el) {
    el.classList.toggle('collapsed');
    var children = el.nextElementSibling;
    if (children && children.classList.contains('tree-children')) {
        children.style.display = children.style.display === 'none' ? '' : 'none';
    }
}

// Modal open/close
function openModal(id) {
    var modal = document.getElementById(id);
    if (modal) modal.classList.add('open');
}
function closeModal(id) {
    var modal = document.getElementById(id);
    if (modal) modal.classList.remove('open');
}

// Close modal on overlay click
document.addEventListener('click', function(e) {
    if (e.target.classList.contains('modal-overlay')) {
        e.target.classList.remove('open');
    }
});

// Add custom tag
function addCustomTag(btn) {
    var input = btn.previousElementSibling;
    var val = input.value.trim();
    if (val) {
        var span = document.createElement('span');
        span.className = 'tag-item selected';
        span.textContent = val;
        span.onclick = function() { this.classList.toggle('selected'); };
        var sep = input.previousElementSibling;
        btn.parentElement.insertBefore(span, sep);
        input.value = '';
    }
}

// Measure selection modal
function toggleAllMeasures(checked) {
    document.querySelectorAll('.measure-ck').forEach(function(cb) { cb.checked = checked; });
    updateMeasureCount();
}
function updateMeasureCount() {
    var count = document.querySelectorAll('.measure-ck:checked').length;
    document.getElementById('selMeasureCount').textContent = count;
}
function confirmSelectMeasure() {
    var checked = document.querySelectorAll('.measure-ck:checked');
    if (checked.length === 0) { alert('请至少选择一条措施'); return; }
    var names = [];
    checked.forEach(function(cb) { names.push(cb.dataset.name); });
    closeModal('modal-select-measure');
    alert('已选择 ' + checked.length + ' 条措施：' + names.join('、'));
}
function filterMeasureTable() {
    var kw = document.getElementById('measureSearchInput').value.trim().toLowerCase();
    var risk = document.getElementById('measureRiskFilter').value;
    document.querySelectorAll('#measureSelectBody tr').forEach(function(tr) {
        var name = tr.querySelector('.smt-name').textContent.toLowerCase();
        var desc = tr.querySelector('.smt-desc').textContent.toLowerCase();
        var riskText = tr.querySelector('.smt-risk').textContent;
        var matchKw = !kw || name.indexOf(kw) !== -1 || desc.indexOf(kw) !== -1;
        var matchRisk = !risk || risk.indexOf(riskText) !== -1;
        tr.style.display = (matchKw && matchRisk) ? '' : 'none';
    });
}
// Auto update count on checkbox click
document.addEventListener('change', function(e) {
    if (e.target.classList.contains('measure-ck')) updateMeasureCount();
});
</script>
</body>
</html>
