<!-- 查看风险条目（9行布局，全部只读） -->
<div class="modal-overlay" id="modal-view-item">
    <div class="modal-box">
        <div class="modal-header">
            <div class="modal-title"><i class="fa-solid fa-eye" style="color:var(--primary)"></i> 查看风险条目</div>
            <button class="modal-close" onclick="closeModal('modal-view-item')">×</button>
        </div>
        <div class="modal-body">
            <!-- Row 1 -->
            <div class="form-row-2">
                <div class="form-group">
                    <label class="form-label">分类编码 <span style="font-size:11px;font-weight:400">（系统自动生成）</span></label>
                    <input type="text" class="form-control" value="FX-2026-0001" readonly>
                </div>
                <div class="form-group">
                    <label class="form-label">推送巡查任务节点</label>
                    <select class="form-control" disabled><option selected>使用维护阶段</option></select>
                </div>
            </div>
            <!-- Row 2 -->
            <div class="form-row-2">
                <div class="form-group">
                    <label class="form-label">主项</label>
                    <input type="text" class="form-control" value="建筑结构信息" readonly>
                </div>
                <div class="form-group">
                    <label class="form-label">分项</label>
                    <input type="text" class="form-control" value="地基基础" readonly>
                </div>
            </div>
            <!-- Row 3 -->
            <div class="form-group" style="margin-bottom:16px">
                <label class="form-label">分项内容（部位）</label>
                <textarea class="form-control" rows="3" readonly>地基基础情况</textarea>
            </div>
            <!-- Row 4 -->
            <div class="form-group" style="margin-bottom:16px">
                <label class="form-label">风险辨识</label>
                <div class="rte-toolbar" style="opacity:0.6;pointer-events:none">
                    <button class="rte-btn"><b>B</b></button><button class="rte-btn"><i>I</i></button><button class="rte-btn"><u>U</u></button><span class="sep"></span><button class="rte-btn">🖼</button><button class="rte-btn">📎</button>
                </div>
                <div class="rte-content" contenteditable="false" style="opacity:0.85">地基基础局部或整体塌陷；上部结构不均匀沉降裂缝严重，且继续发展尚未稳定，或已出现明显倾斜。</div>
                <div style="display:flex;gap:12px;margin-top:6px;font-size:11px;color:var(--text-secondary);">
                    <span>📎 已插入：图片 0 个 · 文档 0 个 · 视频 0 个</span>
                </div>
            </div>
            <!-- Row 5 -->
            <div class="form-group" style="margin-bottom:16px">
                <label class="form-label">可能导致事故</label>
                <div style="display:flex;gap:6px;flex-wrap:wrap">
                    <span class="tag-item selected" style="cursor:default">房屋倾斜或倒塌</span>
                </div>
            </div>
            <!-- Row 6 -->
            <div class="form-row-3">
                <div class="form-group">
                    <label class="form-label">风险标识</label>
                    <div class="risk-level-radio">
                        <label class="active-red" style="cursor:default"><span class="risk-dot red"></span> 红色</label>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">监管内容状态</label>
                    <div style="display:flex;align-items:center;gap:8px">
                        <span style="padding:4px 14px;border-radius:6px;background:rgba(30,142,62,0.12);color:var(--success);font-size:12px;font-weight:600;border:1px solid rgba(30,142,62,0.2)">启用</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">排序</label>
                    <input type="number" class="form-control" value="1" readonly style="text-align:center">
                </div>
            </div>
            <!-- Row 7 -->
            <div class="form-group" style="margin-bottom:16px">
                <label class="form-label">主要防范措施</label>
                <div style="padding:12px 14px;background:var(--bg-dark);border:1px solid var(--border);border-radius:6px;margin-bottom:8px">
                    <div style="font-size:12px;color:var(--text-secondary);margin-bottom:8px">已关联措施：</div>
                    <div style="display:flex;gap:6px;flex-wrap:wrap">
                        <span class="measure-tag">维修加固</span>
                    </div>
                </div>
                <textarea class="form-control" rows="2" readonly>进行安全鉴定，按照鉴定结论进行整改</textarea>
            </div>
            <!-- Row 8 -->
            <div class="form-group" style="margin-bottom:16px">
                <label class="form-label">工作依据</label>
                <div style="display:flex;gap:6px;flex-wrap:wrap">
                    <span class="tag-item selected" style="cursor:default">《农村住房安全性鉴定技术导则》</span>
                </div>
            </div>
            <!-- Row 9 -->
            <div class="form-group" style="margin-bottom:0">
                <label class="form-label">备注</label>
                <textarea class="form-control" rows="2" readonly>该条目为农村自建房核心风险条目，需重点关注。红色等级表示疑似危房状态。</textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('modal-view-item')">关闭</button>
        </div>
    </div>
</div>

