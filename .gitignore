# 忽略备份、临时和依赖目录
.backups/
backups/
*/full_backup_*/
*/backup_*/
*.backup
temp/
node_modules/
dist/
build/

# 忽略运行时生成数据
data/*
!data/.gitkeep
*.log
*.tmp
*.swp
*.swo

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略 IDE 配置
.vscode/
.idea/

# 忽略 Python 缓存
__pycache__/
*.pyc
*.pyo

# 忽略 Office 临时文件
~$*.xlsx
~$*.xls
~$*.docx
~$*.doc
